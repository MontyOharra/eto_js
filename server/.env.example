# Transformation Pipeline Server Configuration

# Server settings
PIPELINE_PORT=8000
PIPELINE_HOST=0.0.0.0
DEBUG=true
RELOAD=true
WORKERS=1

# Logging settings
LOG_LEVEL=INFO
LOG_COLORS=true
LOG_TRACEBACKS=true
LOGS_DIR=logs

# Database Configuration
# Multiple database connections are supported for different purposes

# Main Database (REQUIRED)
# Primary application database for ETO runs, PDFs, pipelines, templates, etc.
DATABASE_URL="mssql+pyodbc://test:test@localhost:49172/eto?driver=ODBC+Driver+17+for+SQL+Server&TrustServerCertificate=yes"

# Orders Database (OPTIONAL)
# Legacy HTC orders database for CreateOrder action module
# If not configured, action modules requiring orders_db will fail with helpful error
# Uncomment and configure to enable order creation functionality:
# ORDERS_DB_CONNECTION_STRING="mssql+pyodbc://user:pass@server:port/htc_orders?driver=ODBC+Driver+17+for+SQL+Server&TrustServerCertificate=yes"
