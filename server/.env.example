# Transformation Pipeline Server Configuration

# Server settings
PIPELINE_PORT=8000
PIPELINE_HOST=0.0.0.0
DEBUG=true
RELOAD=true
WORKERS=1

# Logging settings
LOG_LEVEL=INFO
LOG_COLORS=true
LOG_TRACEBACKS=true
LOGS_DIR=logs
PYTHONUNBUFFERED=1

# Database Configuration
# Multiple database connections are supported for different purposes

# Main Database (REQUIRED)
# Primary application database for ETO runs, PDFs, pipelines, templates, etc.
DATABASE_URL="mssql+pyodbc://test:test@localhost:49172/eto?driver=ODBC+Driver+17+for+SQL+Server&TrustServerCertificate=yes"

# Orders Database (OPTIONAL)
# Legacy HTC orders database for CreateOrder action module
# Supports both SQL Server (SQLAlchemy) and Microsoft Access (pyodbc) databases
# Connection type is auto-detected based on connection string format

# For Microsoft Access database (.mdb or .accdb):
# Requires Microsoft Access Database Engine or full Access installation
# Ensure 32-bit vs 64-bit matches your Python installation
# Use forward slashes (/) in file paths, not backslashes (\)
# HTC_DB_CONNECTION_STRING="Driver={Microsoft Access Driver (*.mdb, *.accdb)};DBQ=C:/HTC_Apps_Full-8-20-25/HTC300_Data-01-01.accdb;"