# Transformation Pipeline Server Configuration

# Server settings
PIPELINE_PORT=8000
PIPELINE_HOST=0.0.0.0
DEBUG=true
RELOAD=true
WORKERS=1

# Logging settings
LOG_LEVEL=INFO
LOG_COLORS=true
LOG_TRACEBACKS=true
LOGS_DIR=logs
PYTHONUNBUFFERED=1

# Database Configuration
# Multiple database connections are supported for different purposes

# Main Database (REQUIRED)
# Primary application database for ETO runs, PDFs, pipelines, templates, etc.
DATABASE_URL="mssql+pyodbc://test:test@localhost:49172/eto?driver=ODBC+Driver+17+for+SQL+Server&TrustServerCertificate=yes"

# HTC Apps Directory (OPTIONAL)
# Root directory for HTC Access databases and attachment storage
# Database connections are built automatically from this path:
#   - htc_000: HTC000_Data_Staff.accdb (user authentication)
#   - htc_300: HTC300_Data-01-01.accdb (orders database)
#   - htc_350d: HTC350D_Database.accdb (address swaps)
# Attachment storage path: {HTC_APPS_DIR}/HTCAttach-{CoID}-{BrID}/...
# Use forward slashes (/) in file paths, not backslashes (\)
HTC_APPS_DIR="C:/HTC_Apps"

OPENAI_API_KEY="your-openai-api-key-here"