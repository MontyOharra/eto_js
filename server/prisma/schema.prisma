// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model PdfFile {
  id                String   @id @default(cuid())
  sha256            String   @unique @db.VarChar(64)
  path              String   @db.NVarChar(512)
  receivedAt        DateTime @db.DateTime2
  sourceMessageId   String?  @db.NVarChar(255)
  createdAt         DateTime @default(now()) @db.DateTime2
  updatedAt         DateTime @updatedAt @db.DateTime2

  // Relations
  signatureMatches SignatureMatch[]
  extractions      Extraction[]

  @@map("pdf_files")
}

model PdfSignature {
  id           String   @id @default(cuid())
  name         String   @db.NVarChar(255)
  customerId   String?  @db.NVarChar(255)
  version      Int      @default(1)
  active       Boolean  @default(true)
  anchorsJson  String   @db.NVarChar(4000) // JSON string
  anchorsHash  String   @db.VarChar(64)
  createdAt    DateTime @default(now()) @db.DateTime2
  updatedAt    DateTime @updatedAt @db.DateTime2

  // Relations
  signatureMatches SignatureMatch[]
  extractionRules  ExtractionRule[]

  @@map("pdf_signatures")
}

model ExtractionRule {
  id           String   @id @default(cuid())
  signatureId  String
  version      Int      @default(1)
  active       Boolean  @default(true)
  specJson     String   @db.NVarChar(4000) // JSON string
  createdAt    DateTime @default(now()) @db.DateTime2
  updatedAt    DateTime @updatedAt @db.DateTime2

  // Relations
  signature   PdfSignature @relation(fields: [signatureId], references: [id])
  extractions Extraction[]

  @@map("extraction_rules")
}

model SignatureMatch {
  id           String   @id @default(cuid())
  fileId       String
  signatureId  String
  score        Int
  decidedAt    DateTime @default(now()) @db.DateTime2
  createdAt    DateTime @default(now()) @db.DateTime2

  // Relations
  file      PdfFile      @relation(fields: [fileId], references: [id])
  signature PdfSignature @relation(fields: [signatureId], references: [id])

  @@map("signature_matches")
}

model Extraction {
  id           String   @id @default(cuid())
  fileId       String
  signatureId  String
  ruleId       String
  status       String   @db.NVarChar(32)
  fieldsJson   String?  @db.NVarChar(4000) // JSON string
  errorsJson   String?  @db.NVarChar(4000) // JSON string
  createdAt    DateTime @default(now()) @db.DateTime2
  updatedAt    DateTime @updatedAt @db.DateTime2

  // Relations
  file      PdfFile        @relation(fields: [fileId], references: [id])
  signature PdfSignature   @relation(fields: [signatureId], references: [id])
  rule      ExtractionRule @relation(fields: [ruleId], references: [id])

  @@map("extractions")
}

model Job {
  id           String   @id @default(cuid())
  type         String   @db.NVarChar(50)
  status       String   @db.NVarChar(32) // pending, processing, completed, failed
  payload      String?  @db.NVarChar(4000) // JSON string
  result       String?  @db.NVarChar(4000) // JSON string
  error        String?  @db.NVarChar(1000)
  attempts     Int      @default(0)
  maxAttempts  Int      @default(3)
  nextAttempt  DateTime? @db.DateTime2
  startedAt    DateTime? @db.DateTime2
  completedAt  DateTime? @db.DateTime2
  createdAt    DateTime @default(now()) @db.DateTime2
  updatedAt    DateTime @updatedAt @db.DateTime2

  @@map("jobs")
}
