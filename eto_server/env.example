# Unified ETO Server Configuration
# Copy this file to .env and update with your actual values

# Core Application Settings
DATABASE_URL=mssql+pyodbc://user:pass@server/eto_unified?driver=ODBC+Driver+17+for+SQL+Server
SECRET_KEY=unified-eto-server-secret-key-change-in-production
FLASK_ENV=production
PORT=8080

# Email Integration Settings
EMAIL_SERVER=outlook.office365.com
EMAIL_USERNAME=
EMAIL_PASSWORD=

# PDF Processing Settings
PDF_STORAGE_PATH=storage/pdfs
MAX_PDF_SIZE_MB=50

# Processing Control Settings
MAX_CONCURRENT_RUNS=5
PROCESSING_TIMEOUT_MINUTES=30