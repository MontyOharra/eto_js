{
  "name": "eto-client",
  "private": true,
  "version": "0.0.0",
  "author": "ethan",
  "description": "ETO Desktop Client",
  "type": "module",
  "main": "./build/dist-electron/main/index.cjs",
  "scripts": {
    "typecheck": "tsc -p src",
    "build:main": "node scripts/build-main.mjs",
    "build:preload": "node scripts/build-preload.mjs",
    "build:electron": "npm run build:main && npm run build:preload",
    "dev": "rm -rf build && npm-run-all --parallel dev:react dev:electron",
    "dev:react": "vite",
    "dev:electron": "cross-env NODE_ENV=development npm run build:electron && electron .",
    "build": "rm -rf build && cross-env NODE_ENV=production npm run build:react && cross-env NODE_ENV=production npm run build:electron",
    "build:react": "vite build",
    "dist:win": "rm -rf dist && npm run build && electron-builder --windows"
  },
  "dependencies": {
    "@tanstack/react-router-devtools": "^1.124.0",
    "@xyflow/react": "^12.8.6",
    "axios": "^1.7.2",
    "dagre": "^0.8.5",
    "dotenv": "^17.0.1",
    "keytar": "^7.9.0",
    "pdfjs-dist": "^5.3.31",
    "rc-slider": "^11.1.9",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-pdf": "^10.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@tailwindcss/vite": "^4.1.11",
    "@tanstack/react-query": "^5.59.0",
    "@tanstack/react-query-devtools": "^5.59.0",
    "@tanstack/react-router": "^1.124.0",
    "@tanstack/router-plugin": "^1.124.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.21",
    "cross-env": "^7.0.3",
    "electron": "^37.1.0",
    "electron-builder": "^26.0.12",
    "esbuild": "^0.25.5",
    "eslint": "^9.25.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.11",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.30.1",
    "vite": "^6.3.5"
  }
}
