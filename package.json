{
  "name": "eto_js",
  "private": true,
  "version": "0.0.0",
  "author": "ethan",
  "description": "testing build",
  "type": "module",
  "main": "./build/dist-electron/main/index.js",
  "scripts": {
    "transpile:electron": "tsc -p src/electron/main/tsconfig.json",
    "bundle:preload": "node scripts/build-preload.mjs",
    "bundle:preload:prod": "cross-env NODE_ENV=production node scripts/build-preload.mjs",
    "setup:python": "node scripts/setup-python.mjs",
    "dev:react": "vite",
    "dev:electron": "npm run transpile:electron && npm run bundle:preload && cross-env NODE_ENV=development electron .",
    "dev": "npm-run-all --parallel dev:react dev:electron",
    "build:react": "tsc -b && vite build",
    "build:electron": "npm run transpile:electron && npm run bundle:preload:prod",
    "build:all": "npm run build:electron && npm run build:react",
    "lint": "eslint .",
    "dist:win": "rm -rf build && rm -rf dist && npm run build:all && electron-builder --win",
    "dist:mac": "npm run build:all && electron-builder --mac",
    "dist:linux": "npm run build:all && electron-builder --linux",
    "dist:all": "npm run build:all && electron-builder"
  },
  "dependencies": {
    "@tanstack/react-router": "^1.123.2",
    "pdfjs-dist": "^5.3.31",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-pdf": "^10.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "cross-env": "^7.0.3",
    "electron": "^37.1.0",
    "electron-builder": "^26.0.12",
    "esbuild": "^0.25.5",
    "eslint": "^9.25.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "npm-run-all": "^4.1.5",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.30.1",
    "vite": "^6.3.5"
  }
}
