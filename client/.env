# Environment variables declared in this file are automatically made available to Prisma.
# See the documentation for more detail: https://pris.ly/d/prisma-schema#accessing-environment-variables-from-the-schema

# Prisma supports the native connection string format for PostgreSQL, MySQL, SQLite, SQL Server, MongoDB and CockroachDB.
# See the documentation for all the connection string options: https://pris.ly/d/connection-strings

# The following `prisma+postgres` URL is similar to the URL produced by running a local Prisma Postgres 
# server with the `prisma dev` CLI command, when not choosing any non-default ports or settings. The API key, unlike the 
# one found in a remote Prisma Postgres URL, does not contain any sensitive information.

# SQL Server Auth
#  DB_AUTH_TYPE=sql
#  DB_USER=sa
#  DB_PASSWORD=your_password

# Windows Auth (no credentials needed)
DB_AUTH_TYPE="integrated"
DB_SERVER="localhost"
DB_PORT="49172"
DB_NAME="HTC"
DB_ENCRYPT="false"
DB_INTEGRATED_SECURITY="true"
DB_TRUST_SERVER_CERTIFICATE="true"

DATABASE_URL = "sqlserver://localhost:49172;database=HTC;encrypt=false;trustServerCertificate=true;integratedSecurity=true"
# Azure SQL
#  DB_AUTH_TYPE=azure
#  DB_AZURE_USER=user@domain.com
#  DB_AZURE_PASSWORD=password

