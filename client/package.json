{
  "name": "eto_js",
  "private": true,
  "version": "0.0.0",
  "author": "ethan",
  "description": "testing build",
  "type": "module",
  "main": "./build/dist-electron/main/index.js",
  "scripts": {
    "prisma:generate": "prisma generate",
    "prisma:pull": "prisma db pull",
    "build:python": "node scripts/setup-python.mjs",
    "build:prisma": "node scripts/copy-prisma.mjs",
    "transpile:electron": "tsc -p src/main/tsconfig.json",
    "dev:build:electron:preload": "node scripts/build-preload.mjs",
    "dev:build:electron:main": "npm run transpile:electron",
    "dev:build:electron": "npm run dev:build:electron:preload && npm run dev:build:electron:main && cross-env NODE_ENV=development electron .",
    "dev:build:react": "vite",
    "dev:build:prisma": "npm run prisma:generate && npm run build:prisma",
    "dev:build": "npm-run-all --parallel dev:build:react dev:build:electron dev:build:prisma",
    "dev": "rm -rf build && npm run dev:build",
    "prod:build:electron:preload": "cross-env NODE_ENV=production node scripts/build-preload.mjs",
    "prod:build:electron:main": "npm run transpile:electron",
    "prod:build:electron": "npm run transpile:electron && npm run build:bundle:preload",
    "prod:build:react": "tsc -b && vite build",
    "prod:build": "npm run build:electron && npm run build:react",
    "lint": "eslint .",
    "dist:win": "rm -rf build && rm -rf dist && npm run prod:build && electron-builder --win",
    "dist:mac": "rm -rf build && rm -rf dist && npm run prod:build && electron-builder --mac",
    "dist:linux": "rm -rf build && rm -rf dist && npm run prod:build && electron-builder --linux",
    "dist:all": "rm -rf build && rm -rf dist && npm run prod:build && electron-builder"
  },
  "dependencies": {
    "@prisma/client": "^6.11.0",
    "@tanstack/react-router-devtools": "^1.124.0",
    "pdfjs-dist": "^5.3.31",
    "prisma": "^6.11.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-pdf": "^10.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@tanstack/react-router": "^1.124.0",
    "@tanstack/router-plugin": "^1.124.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "cross-env": "^7.0.3",
    "electron": "^37.1.0",
    "electron-builder": "^26.0.12",
    "esbuild": "^0.25.5",
    "eslint": "^9.25.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "npm-run-all": "^4.1.5",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.30.1",
    "vite": "^6.3.5"
  }
}