{
  "name": "eto_js",
  "private": true,
  "version": "0.0.0",
  "author": "ethan",
  "description": "testing build",
  "type": "module",
  "main": "./build/dist-electron/main/index.cjs",
  "scripts": {
    "typecheck": "tsc -p src",
    "build:main": "node scripts/build-main.mjs",
    "dev": "rm -rf build && npm-run-all --parallel dev:react dev:electron",
    "dev:react": "vite",
    "dev:electron": "cross-env NODE_ENV=development npm run build:main && node scripts/build-preload.mjs && electron .",
    "build": "rm -rf build && cross-env NODE_ENV=production npm run prisma:generate && npm run build:react && npm run build:electron",
    "build:react": "vite build",
    "build:electron": "cross-env NODE_ENV=production npm run build:main && node scripts/build-preload.mjs",
    "prisma:generate": "prisma generate",
    "dist:win": "rm -rf dist && npm run build && electron-builder --windows"
  },
  "dependencies": {
    "@prisma/client": "^6.11.0",
    "@tanstack/react-router-devtools": "^1.124.0",
    "dotenv": "^17.0.1",
    "keytar": "^7.9.0",
    "pdfjs-dist": "^5.3.31",
    "prisma": "^6.11.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-pdf": "^10.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@tanstack/react-router": "^1.124.0",
    "@tanstack/router-plugin": "^1.124.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "cross-env": "^7.0.3",
    "electron": "^37.1.0",
    "electron-builder": "^26.0.12",
    "esbuild": "^0.25.5",
    "eslint": "^9.25.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "npm-run-all": "^4.1.5",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.30.1",
    "vite": "^6.3.5"
  }
}
