{
  "modules": [
    {
      "id": "basic_text_cleaner",
      "version": "1.0.0",
      "title": "Basic Text Cleaner",
      "description": "Clean and normalize text by removing extra whitespace and applying basic transformations",
      "kind": "transform",
      "category": "Text",
      "color": "#EC4899",
      "meta": {
        "io_shape": {
          "inputs": {
            "nodes": [
              {
                "label": "input_text",
                "min_count": 1,
                "max_count": 1,
                "typing": {
                  "allowed_types": ["str"]
                }
              }
            ]
          },
          "outputs": {
            "nodes": [
              {
                "label": "cleaned_text",
                "min_count": 1,
                "max_count": 1,
                "typing": {
                  "allowed_types": ["str"]
                }
              }
            ]
          }
        }
      },
      "config_schema": {
        "type": "object",
        "properties": {
          "strip_whitespace": {
            "type": "boolean",
            "title": "Strip Whitespace",
            "description": "Remove leading/trailing whitespace",
            "default": true
          },
          "normalize_spaces": {
            "type": "boolean",
            "title": "Normalize Spaces",
            "description": "Convert multiple spaces to single space",
            "default": true
          },
          "remove_empty_lines": {
            "type": "boolean",
            "title": "Remove Empty Lines",
            "description": "Remove empty lines",
            "default": false
          },
          "to_lowercase": {
            "type": "boolean",
            "title": "To Lowercase",
            "description": "Convert text to lowercase",
            "default": false
          }
        }
      }
    },
    {
      "id": "data_duplicator",
