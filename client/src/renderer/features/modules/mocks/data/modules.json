    {
      "id": "type_converter",
      "version": "1.0.0",
      "title": "Type Converter",
      "description": "Convert data from one type to another (string, number, boolean)",
      "kind": "transform",
      "category": "Data",
      "color": "#8B5CF6",
      "meta": {
        "io_shape": {
          "inputs": {
            "nodes": [
              {
                "label": "input",
                "min_count": 1,
                "max_count": 1,
                "typing": {
                  "allowed_types": ["str", "int", "float", "bool"]
                }
              }
            ]
          },
          "outputs": {
            "nodes": [
              {
                "label": "output",
                "min_count": 1,
                "max_count": 1,
                "typing": {
                  "allowed_types": ["str", "int", "float", "bool"]
                }
              }
            ]
          }
        }
      },
      "config_schema": {
        "type": "object",
        "properties": {
          "target_type": {
            "type": "string",
            "title": "Target Type",
            "description": "Type to convert to",
            "enum": ["str", "int", "float", "bool"],
            "default": "str"
          },
          "strict_mode": {
            "type": "boolean",
            "title": "Strict Mode",
            "description": "Fail on conversion errors instead of using defaults",
            "default": true
          }
        },
        "required": ["target_type"]
      }
    },
